generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  pin       String?
  otps      Otp[]
  createdAt DateTime @default(now())
}

model Otp {
  id        Int      @id @default(autoincrement())
  code      String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model MenuItem {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Int
  image       String
  category    String
  reviews     Review[]
  orders      Order[] //MenuItem-г Order-той холбох
}

model Review {
  id          Int      @id @default(autoincrement())
  studentName String
  rating      Int
  review      String?
  createdAt   DateTime @default(now())

  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId Int

  // Оюутан нэг хоолонд нэг л үнэлгээ өгөх боломжтой
  @@unique([studentName, menuItemId])
}

model Order {
  id          Int    @id @default(autoincrement())
  studentName String
  itemName    String // Түүхэнд харагдах нэр
  quantity    Int
  status      String @default("PENDING")

  // ЧУХАЛ: Refresh хийх үед Review-г олж ирэх холбоос
  menuItemId Int?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id])

  rating Int? // Энэ нь тухайн захиалгад өгсөн түр зуурын утга байж болно
  review String?

  createdAt DateTime @default(now())
}
